+// ─── Utility: Format Views ───────────────────────────────────────────────────
+function formatViews(views: string): string {
+  const v = parseInt(views, 10);
+  if (isNaN(v)) return '';
+  if (v >= 1000000) return `${(v / 1000000).toFixed(1)}M`;
+  if (v >= 1000) return `${(v / 1000).toFixed(1)}K`;
+  return String(v);
+}
