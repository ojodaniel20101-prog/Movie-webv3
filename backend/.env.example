PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
DB_PATH=./db/zentrix.db

# Football Data API (optional - get free key at football-data.org)
# Without this key, demo data will be shown for match statistics
FOOTBALL_DATA_API_KEY=your-football-data-api-key

# RapidAPI Key for API-Football (optional backup source)
RAPIDAPI_KEY=your-rapidapi-key
